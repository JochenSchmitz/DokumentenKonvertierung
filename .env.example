# --- Datenbank (Postgres 18.3, Container fds-db) ---
POSTGRES_DB=dokumente
POSTGRES_USER=dokumente
POSTGRES_PASSWORD=<sicheres-passwort>
DATABASE_URL=postgresql+psycopg://dokumente:<sicheres-passwort>@localhost:5435/dokumente

# --- OnlyOffice (bestehender Container vip-onlyoffice-1) ---
ONLYOFFICE_JWT_SECRET=<onlyoffice-jwt-secret>

# --- ngrok (Bezahlversion, reservierte Domain) ---
NGROK_AUTHTOKEN=<dein-ngrok-authtoken>
NGROK_DOMAIN=fds.ngrok.app

# --- Netz ---
PUBLIC_HOST=172.31.102.13
BACKEND_PORT=8020

# --- Anmeldung (Sitzung: 7 Tage) ---
AUTH_SECRET=<64-hex-zeichen-zufallswert>
AUTH_SESSION_DAYS=7
AUTH_USERS=<email1>:<passwort1>,<email2>:<passwort2>

# OCR-Modell-Endpunkte.
# Einzelner Server (Standard): VLLM_URL zeigt direkt auf das vLLM, mehr
# ist nicht nötig. Mehr-GPU-Betrieb: VLLM_URL zeigt auf den haproxy-LB
# (docker-compose Service vllm-lb, :8013), der auf mehrere vLLMs verteilt;
# VLLM_ENDPOINTS listet die realen vLLMs (kommagetrennt) für Health/Metrik.
#VLLM_URL=http://localhost:8013/v1
#VLLM_ENDPOINTS=http://localhost:8012/v1,http://172.31.102.12:8012/v1

# OCR_PARALLEL = globales Seitenbudget (alle Dokumente zusammen).
# DOC_PARALLEL = wie viele Dokumente gleichzeitig verarbeitet werden (1 =
# eins nach dem anderen; bei mehreren GPUs hinter dem LB höher, damit auch
# viele kleine Dokumente beide GPUs auslasten).
# ENTITY_PARALLEL = Nebenläufigkeit des Beteiligten-Nachlaufs.
OCR_PARALLEL=12
DOC_PARALLEL=1
ENTITY_PARALLEL=8
